# ============================================================
# gPawa / Energy Sharing — Production Environment Variables
# Copy this file to .env on the server and fill in real values.
# NEVER commit the real .env file to version control.
# ============================================================

# ---- App -------------------------------------------------------
SECRET_KEY=REPLACE_WITH_50+_RANDOM_CHARS   # python -c "import secrets; print(secrets.token_urlsafe(60))"
DEBUG=False

# ---- URLs ------------------------------------------------------
# The public domain for the backend API
BASE_URL=https://energy-share.sun.ac.ug/api/v1
# The public domain for the frontend (used in verification/reset emails)
FRONTEND_URL=https://energy-share.sun.ac.ug
# CORS / CSRF: must match the frontend origin exactly
PRODUCTION_ORIGIN=https://energy-share.sun.ac.ug
# Any extra hostnames Django should accept (comma-separated, no spaces)
EXTRA_ALLOWED_HOSTS=energy-share.sun.ac.ug

# ---- Database --------------------------------------------------
DB_NAME=metering
DB_USER=gpawa_app           # dedicated DB role — NOT postgres superuser
DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
DB_HOST=localhost
DB_PORT=5432

# ---- Email (Gmail SMTP with App Password) ----------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=gpawateam@gmail.com
EMAIL_HOST_PASSWORD=REPLACE_WITH_GMAIL_APP_PASSWORD
DEFAULT_EMAIL_SENDER=gpawateam@gmail.com

# ---- Celery / Redis (always-eager for the pilot — no worker needed) ---
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
CELERY_TIMEZONE=Africa/Kampala
CELERY_TASK_ALWAYS_EAGER=False  # Production: run celery worker + beat for AMI usage snapshots

# ---- MTN MoMo (sandbox for pilot; swap to production when ready) ------
MTN_SUBSCRIPTION_KEY=REPLACE_WITH_MTN_KEY
MTN_API_KEY=REPLACE_WITH_MTN_API_KEY
MTN_API_USER_ID=REPLACE_WITH_MTN_USER_ID
MTN_CALLBACK_HOST=https://energy-share.sun.ac.ug
MTN_ENVIRONMENT=sandbox     # Change to 'production' with real credentials

# ---- ThingsBoard (AMI meters) ----------------------------------
THINGSBOARD_BASE_URL=https://iot.energy-share.sun.ac.ug
THINGSBOARD_TIMEOUT_SECONDS=8
THINGSBOARD_WEBHOOK_SECRET=choose-a-long-random-string
THINGSBOARD_TENANT_USERNAME=              # Optional: Power Usage timeseries
THINGSBOARD_TENANT_PASSWORD=
THINGSBOARD_USAGE_TELEMETRY_KEY=daily_kwh
# Use real ThingsBoard push/read for AMI apply + check-units (default is mock simulation):
AMI_GATEWAY=utils.ami_gateway.ThingsBoardAMIGateway
CRB_PROVIDER=loan.crb.NoOpCreditBureauProvider

# ---- Lending compliance (statutory caps — do not increase without legal review) ----
MAX_MONTHLY_INTEREST_RATE_PCT=2.8
MAX_CUMULATIVE_CHARGES_MULTIPLIER=1.0

# ---- HTTP protocol (https in production) --------------------------------
DEFAULT_HTTP_PROTOCOL=https
DOMAIN_NAME=energy-share.sun.ac.ug
