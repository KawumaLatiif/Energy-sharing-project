# gPawa Mobile — API URL (no trailing slash)
# This value is BAKED INTO THE APK at build time. Rebuild after any change.

# ── Physical phone on same Wi-Fi as your PC ─────────────────────────────
# Run `ipconfig` → use IPv4 under "Wireless LAN adapter Wi-Fi"
# NOT VMware addresses (192.168.189.x / 192.168.79.x)
EXPO_PUBLIC_API_URL=http://192.168.1.130:8000/api/v1

# ── Android emulator only (maps to host PC localhost) ───────────────────
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8000/api/v1

# ── Hosted production (PC does not need to run) ─────────────────────────
# EXPO_PUBLIC_API_URL=https://energy-share.sun.ac.ug/api/v1
