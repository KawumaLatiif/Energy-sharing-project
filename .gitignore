# =============================================================================
# gPawa monorepo — files and folders that should stay local
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets and environment files
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
*.pem
*.key
*.p12
secrets/
credentials.json

# -----------------------------------------------------------------------------
# Python / Django (backend)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
backend/venv/

# Django runtime artifacts
backend/staticfiles/
backend/mediafiles/
staticfiles/
mediafiles/
*.sqlite3
db.sqlite3
local_settings.py

# Test / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/

# Celery
celerybeat-schedule
celerybeat.pid

# -----------------------------------------------------------------------------
# Node.js / Next.js (frontend)
# -----------------------------------------------------------------------------
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/

# Next.js build output
.next/
frontend/.next/
out/
frontend/out/
build/
frontend/build/
dist/
frontend/dist/
.turbo/
.vercel/

# TypeScript
*.tsbuildinfo

# -----------------------------------------------------------------------------
# IDE and editor files
# -----------------------------------------------------------------------------
.idea/
*.iml
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# Cursor / Claude local agent settings
.claude/
.cursor/
**/.claude/settings.local.json

# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

