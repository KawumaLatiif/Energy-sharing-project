# Logs and temporary files
# -----------------------------------------------------------------------------
logs/
*.log
*.tmp
*.temp
*.bak
*.orig
~$*

# -----------------------------------------------------------------------------
# Testing / browser automation artifacts
# -----------------------------------------------------------------------------
test-results/
playwright-report/
playwright/.cache/
blob-report/
coverage/

# -----------------------------------------------------------------------------
# Local databases and heavy dumps (keep examples/docs in repo)
# -----------------------------------------------------------------------------
*.dump
*.sql.gz
database/local/
database/*.local.sql

# -----------------------------------------------------------------------------
# Misc local-only folders
# -----------------------------------------------------------------------------
.cache/
tmp/
temp/
Energy-sharing-project/
